{
  "name": "@zonko/slack-mcp",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:worker": "wrangler dev --config wrangler.jsonc",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote --config wrangler.jsonc",
    "test": "vitest run",
    "test:live-tools": "tsx src/testing/test-all-tools.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastmcp": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "wrangler": "^4.90.0"
  }
}
